# Flockora Backend — environment variable template.
# Copy to .env for local development. NEVER commit a real .env file (see SECURITY.md Rule 9).
# This file must never contain real secret values — only placeholder/example config.

# --- Server ---
PORT=8787
NODE_ENV=development

# --- AI provider selection ---
# Only "mock" is implemented as of Phase 3 Sprint 3.1. Any other value fails startup validation.
# A real provider (e.g. "gemini") will be added in a future sprint via the AIProvider abstraction
# in src/providers — see PROJECT_CONTEXT.md for status.
AI_PROVIDER=mock

# --- Upload constraints ---
MAX_UPLOAD_MB=8

# --- Rate limiting (IP-based only; see SECURITY.md Rule 7 — per-user quotas require auth,
#     which does not exist yet anywhere in Flockora) ---
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=20

# --- Request timeout ---
REQUEST_TIMEOUT_MS=15000

# --- CORS ---
# Comma-separated list of allowed origins. Native mobile requests do not send an Origin header,
# so this mainly matters for browser-based testing tools or a future Expo web build.
ALLOWED_ORIGINS=http://localhost:19006

# --- Future AI provider secrets ---
# Per SECURITY.md Rules 1, 2, 3, 5: real provider API keys (Gemini, OpenAI, Claude, etc.) must
# NEVER be defined in this file with real values, must NEVER be committed, and once a real
# provider is integrated they must be injected only via the deployment platform's secure
# environment variable store or secrets manager — never checked into source control.
